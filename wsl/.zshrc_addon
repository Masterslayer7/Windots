# --- WINDOTS WSL INTEGRATION (ZSH) ---
# Environment Variables
export STARSHIP_CONFIG="$HOME/.config/starship/starship.toml"
export BAT_CONFIG_DIR="$HOME/.config/bat"
export FZF_DEFAULT_OPTS='--color=fg:-1,fg+:#ffffff,bg:-1,bg+:#233932 --color=hl:#b3d3e3,hl+:#bce6f2,info:#ebd69b,marker:#8fe4c1 --color=prompt:#bce6f2,spinner:#b8add1,pointer:#e68595,header:#8fe4c1 --color=gutter:-1,border:#2b3f3a,scrollbar:#89a89c,label:#89a89c --color=query:#ffffff --border="rounded" --border-label="" --preview-window="border-rounded" --height 40% --preview="batcat -n --color=always {}"'

# Aliases matching Windows profile
alias bat="batcat"
alias cat="batcat"
alias vi="nvim"
alias vim="nvim"
alias ls="eza -a -l --header --icons --git --hyperlink --time-style=relative"
alias ll="eza -a -l --header --icons --git --hyperlink --time-style=relative"
alias la="eza -a -l -a --header --icons --git --hyperlink --time-style=relative"
alias l="eza -a -l --header --icons --git --hyperlink --time-style=relative"

# Shell Integrations
eval "$(starship init zsh)"
eval "$(zoxide init zsh --cmd cd)"

# Zsh Plugins (Syntax Highlighting & Autosuggestions)
if [ -f "$HOME/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]; then
    source "$HOME/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
fi
if [ -f "$HOME/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
    source "$HOME/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh"
fi

# FZF Key Bindings and Auto-completion (fzf v0.44 compatible)
if [ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]; then
    source /usr/share/doc/fzf/examples/key-bindings.zsh
fi
if [ -f /usr/share/doc/fzf/examples/completion.zsh ]; then
    source /usr/share/doc/fzf/examples/completion.zsh
fi

# Launch fastfetch
if [[ -o interactive ]]; then
    fastfetch
fi

# FZF Helper Aliases
alias fo='nvim $(fzf)'
alias fkill='kill -9 $(ps -ef | fzf --header="Select process to kill" | awk '\''{print $2}'\'')'
alias gco='git checkout $(git branch --all | fzf | tr -d "[:space:]*")'
alias gshow='git log --oneline | fzf --preview "git show {1} --color=always"'
alias fssh='ssh $(grep -i "host " ~/.ssh/config 2>/dev/null | awk '\''{print $2}'\'' | fzf)'

# FZF Custom Completion Generators (using fd for speed and ignoring git/node_modules)
_fzf_compgen_path() {
  fdfind --hidden --follow --exclude ".git" "$1"
}

_fzf_compgen_dir() {
  fdfind --type d --hidden --follow --exclude ".git" "$1"
}
